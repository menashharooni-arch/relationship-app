<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Must match the App target's group so the widget can read the active
	     card written by @capacitor/preferences. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.me.swiftcard.app</string>
	</array>
</dict>
</plist>
