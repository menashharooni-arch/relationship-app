# SwiftCard — Environment Variables
#
# Copy this file to `.env.local` for local dev and fill in real values.
# Add the same variables to Vercel → Settings → Environment Variables for production.
# NEVER commit `.env.local` (or any file with real secrets) to git.

# ── App URL ──────────────────────────────────────────────────────────────────
# Used for card links, email links, and OAuth/webhook redirect URIs — must match
# the domain registered in Google/HubSpot OAuth apps and your Stripe/Twilio dashboards.
NEXT_PUBLIC_APP_URL=https://swiftcard.me

# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin panel ───────────────────────────────────────────────────────────────
# Comma-separated emails allowed into /admin (plan toggling, analytics, promo codes, broadcast).
ADMIN_EMAILS=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Format: "SwiftCard <hello@yourdomain.com>". Must be a verified sender/domain in
# Resend. For local testing you can use "SwiftCard <onboarding@resend.dev>" (Resend
# sandbox — only delivers to your own account email).
RESEND_FROM_EMAIL=

# ── AI follow-up messages ────────────────────────────────────────────────────
# Tried in this order: OPENAI_API_KEY, then GEMINI_API_KEY, then ANTHROPIC_API_KEY.
GEMINI_API_KEY=
GEMINI_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# ── Cron ──────────────────────────────────────────────────────────────────────
# Shared secret for scheduled/cron-triggered routes (e.g. /api/reminders).
CRON_SECRET=

# ── OAuth token encryption (Google/HubSpot CRM sync) ─────────────────────────
# 32-byte key as 64 hex chars. Generate with: openssl rand -hex 32
OAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ── LinkedIn profile-photo import (optional) ─────────────────────────────────
# "Sign In with LinkedIn using OpenID Connect" OAuth app. Lets a user import
# their LinkedIn profile photo onto a card (they approve before it's applied).
# Requires the product to be ADDED and APPROVED on the LinkedIn app — until then
# the Connect button stays hidden (both vars must be set to surface it).
# Redirect URI to register: ${NEXT_PUBLIC_APP_URL}/api/integrations/linkedin/callback
# Scopes: openid profile email
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Company logo suggestion (optional) ───────────────────────────────────────
# Logo.dev Brand Search API secret key (format sk_...). Suggests a company's
# official logo when a user enters a company name / business email / domain.
# Without it, the "Suggest my company logo" helper stays hidden — nothing breaks.
# Get one at https://www.logo.dev (dashboard → API key).
LOGO_DEV_TOKEN=

# ── Web push notifications ───────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Apple Wallet pass (digital business card) ────────────────────────────────
APPLE_PASS_TYPE_ID=
APPLE_TEAM_ID=
APPLE_PASS_CERT_PEM=
APPLE_PASS_KEY_PEM=
APPLE_PASS_KEY_PASSWORD=
APPLE_WWDR_PEM=

# ── App Store link (iOS app promo popup) ─────────────────────────────────────
NEXT_PUBLIC_APP_STORE_URL=

# ══════════════════════════════════════════════════════════════════════════
# Stripe (payments) — see STRIPE_TWILIO_SETUP.md for the full dashboard walkthrough
# ══════════════════════════════════════════════════════════════════════════
#
# Test mode vs. live mode: Stripe keeps ENTIRELY SEPARATE data for test and live
# mode — separate API keys, separate Products/Prices, separate webhook signing
# secrets. A test-mode Price ID will NOT work with a live-mode secret key, and
# vice versa. To go live, create your Products/Prices again in live mode (or
# toggle "View live data" and duplicate them), then swap EVERY value below for
# its live-mode equivalent — do not mix test and live values.
#
# Which mode you're in is determined ENTIRELY by which key you put here:
#   sk_test_... / whsec_... (test endpoint)  → test mode, no real charges
#   sk_live_... / whsec_... (live endpoint)  → live mode, REAL charges
#
# Secret key — Stripe Dashboard → Developers → API keys → Secret key.
STRIPE_SECRET_KEY=

# Webhook signing secret — Dashboard → Developers → Webhooks → your endpoint →
# Signing secret. Test mode and live mode each have their OWN endpoint + secret.
STRIPE_WEBHOOK_SECRET=

# Price IDs — Dashboard → Product catalog → each price → copy the Price ID
# (starts with price_...). These must be recurring (subscription) prices in USD,
# and their amount MUST exactly match the prices shown on /pricing:
#   Pro monthly    → $4.99/mo
#   Pro annual     → $54.00/yr
#   Office monthly → $3.99/mo per seat (2-seat minimum)
#   Office annual  → $43.09/yr per seat (2-seat minimum)
# The checkout route (src/app/api/stripe/checkout/route.ts) verifies the live
# Stripe price against these amounts and refuses checkout on a mismatch — see
# PLAN_PRICES in src/lib/plan.ts, the single source of truth for both numbers.
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=
# Legacy/fallback Pro price ID (used only if a request omits priceId). Safe to
# leave unset if NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID is set.
STRIPE_PRICE_ID=

# Optional: a Stripe Coupon ID offered on the account-cancellation "retain" flow.
STRIPE_RETENTION_COUPON_ID=

# ══════════════════════════════════════════════════════════════════════════
# Twilio (SMS) — see STRIPE_TWILIO_SETUP.md for the full dashboard walkthrough
# ══════════════════════════════════════════════════════════════════════════
#
# Console → Account → Account Info.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Preferred sender: a Messaging Service SID (Console → Messaging → Services).
# Falls back to a single phone number if unset. Set ONE of the two below.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# Inbound-SMS webhook signature check. Leave unset (or "false") in production —
# this exists ONLY to bypass signature validation in local dev when Twilio can't
# reach localhost. Never set to "true" in a deployed environment.
TWILIO_SKIP_VALIDATION=false
